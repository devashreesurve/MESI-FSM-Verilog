module mesi_controller(

    input clk,
    input rst,

    input cpu_read,
    input cpu_write,

    input other_read,
    input other_write,

    output reg [1:0] mesi_state,

    output reg invalidate,
    output reg writeback
);

parameter INVALID   = 2'b00;
parameter SHARED    = 2'b01;
parameter EXCLUSIVE = 2'b10;
parameter MODIFIED  = 2'b11;

always @(posedge clk or posedge rst)
begin

    if(rst)
    begin

        mesi_state <= INVALID;

        invalidate <= 0;

        writeback <= 0;

    end

    else
    begin

        invalidate <= 0;

        writeback <= 0;

        case(mesi_state)

            INVALID:
            begin

                if(cpu_read)
                    mesi_state <= EXCLUSIVE;

                else if(cpu_write)
                    mesi_state <= MODIFIED;

            end

            EXCLUSIVE:
            begin

                if(cpu_write)
                    mesi_state <= MODIFIED;

                else if(other_read)
                    mesi_state <= SHARED;

                else if(other_write)
                begin

                    mesi_state <= INVALID;

                    invalidate <= 1;

                end

            end

            SHARED:
            begin

                if(cpu_write)
                    mesi_state <= MODIFIED;

                else if(other_write)
                begin

                    mesi_state <= INVALID;

                    invalidate <= 1;

                end

            end

            MODIFIED:
            begin

                if(other_read)
                begin

                    mesi_state <= SHARED;

                    writeback <= 1;

                end

                else if(other_write)
                begin

                    mesi_state <= INVALID;

                    invalidate <= 1;

                    writeback <= 1;

                end

            end

            default:
            begin

                mesi_state <= INVALID;

            end

        endcase

    end

end

endmodule
